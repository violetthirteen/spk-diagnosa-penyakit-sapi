{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.0",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "source": "/build/assets/(.*)", "destination": "/public/build/assets/$1" },
    { "source": "/images/(.*)", "destination": "/public/images/$1" },
    { "source": "/profile-photos/(.*)", "destination": "/public/profile-photos/$1" },
    { "source": "/favicon.ico", "destination": "/public/favicon.ico" },
    { "source": "/(.*)", "destination": "/api/index.php" }
  ],
  "buildCommand": "npm run build && php artisan config:cache && php artisan route:cache && php artisan view:cache",
  "installCommand": "composer install --no-dev --optimize-autoloader"
}
